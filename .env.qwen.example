# 基础监听端口
PORT=9000

# MoviePilot 回调地址，同机 Docker 场景下一般保持默认
MP_BASE_URL=http://moviepilot-v2:3001

# MoviePilot 的 API Key
MP_API_KEY=replace_with_moviepilot_api_key

# 推荐默认模式
RECOGNIZER_MODE=direct_llm

# 千问兼容接口根路径，不要带 /chat/completions
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 千问 / 百炼 API Key
LLM_API_KEY=replace_with_dashscope_api_key

# 可按需要替换为 qwen-max 等模型
LLM_MODEL=qwen-plus

# 结构化识别建议保持低温度
LLM_TEMPERATURE=0.1

# 结构化 JSON 场景建议关闭思考
LLM_ENABLE_THINKING=false

# 强烈建议填写，用于最终 TMDB 复核
TMDB_API_KEY=replace_with_tmdb_api_key

# 超时时间（毫秒）
RECOGNIZER_TIMEOUT_MS=60000
