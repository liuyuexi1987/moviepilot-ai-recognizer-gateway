# 基础监听端口
PORT=9000

# MoviePilot 回调地址，同机 Docker 场景下一般保持默认
MP_BASE_URL=http://moviepilot-v2:3001

# MoviePilot 的 API Key
MP_API_KEY=replace_with_moviepilot_api_key

# 推荐接口 1：NVIDIA NIM
# OpenAI 兼容接口根路径，不要带 /chat/completions
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# 你的 NVIDIA / SiliconFlow / 其他兼容提供商 API Key
LLM_API_KEY=replace_with_llm_api_key

# 当前推荐示例：NVIDIA 上的千问 122B
LLM_MODEL=qwen/qwen3.5-122b-a10b

# 结构化识别建议保持低温度
LLM_TEMPERATURE=0.1

# 结构化 JSON 场景建议关闭思考
LLM_ENABLE_THINKING=false

# 强烈建议填写，用于最终 TMDB 复核
TMDB_API_KEY=replace_with_tmdb_api_key

# 超时时间（毫秒）
RECOGNIZER_TIMEOUT_MS=60000
