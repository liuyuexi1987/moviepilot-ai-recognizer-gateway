# 基础监听端口
PORT=9000

# MoviePilot 回调地址
# 同机 Docker / 同网络部署时，一般保持默认即可
MP_BASE_URL=http://moviepilot-v2:3001

# MoviePilot 的 API Key
MP_API_KEY=replace_with_moviepilot_api_key

# 这里填写 OpenAI 兼容接口的根路径，不要带 /chat/completions
# 常见示例：
# - NVIDIA NIM: https://integrate.api.nvidia.com/v1
# - SiliconFlow: https://api.siliconflow.cn/v1
# - OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# 大模型 API Key
LLM_API_KEY=replace_with_llm_api_key

# 模型名示例：
# - qwen/qwen3.5-122b-a10b（NVIDIA 上的千问 122B）
# - deepseek-ai/DeepSeek-V3（具体以提供商支持为准）
# - gpt-4.1-mini
LLM_MODEL=qwen/qwen3.5-122b-a10b

# 结构化识别建议保持较低温度
LLM_TEMPERATURE=0.1

# 结构化 JSON 输出建议关闭思考
LLM_ENABLE_THINKING=false

# 可选但强烈推荐：
# 配置后会对最终 tmdb_id 做 TMDB 复核，避免模型幻觉编号
TMDB_API_KEY=

# 网关等待识别后端的超时时间（毫秒）
RECOGNIZER_TIMEOUT_MS=60000
