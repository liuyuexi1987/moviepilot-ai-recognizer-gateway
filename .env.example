# 基础监听端口
PORT=9000

# MoviePilot 回调地址
# 同机 Docker / 同网络部署时，一般保持默认即可
MP_BASE_URL=http://moviepilot-v2:3001

# MoviePilot 的 API Key
MP_API_KEY=replace_with_moviepilot_api_key

# 识别后端模式：
# - direct_llm：推荐，直接调用 OpenAI 兼容接口
# - external_recognizer：兼容已有 OpenClaw / 外部识别端
RECOGNIZER_MODE=direct_llm

# direct_llm 模式
# 这里填写 OpenAI 兼容接口的根路径，不要带 /chat/completions
# 常见示例：
# - OpenAI: https://api.openai.com/v1
# - 千问兼容接口: https://dashscope.aliyuncs.com/compatible-mode/v1
# - OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 大模型 API Key
LLM_API_KEY=replace_with_llm_api_key

# 模型名示例：
# - qwen-plus
# - qwen-max
# - gpt-4.1-mini
# - openai/gpt-4.1-mini（取决于提供商）
LLM_MODEL=qwen-plus

# 结构化识别建议保持较低温度
LLM_TEMPERATURE=0.1

# 结构化 JSON 输出建议关闭思考
LLM_ENABLE_THINKING=false

# 可选但强烈推荐：
# 配置后会对最终 tmdb_id 做 TMDB 复核，避免模型幻觉编号
TMDB_API_KEY=

# external_recognizer 模式
# 只有在 RECOGNIZER_MODE=external_recognizer 时才使用
OPENCLAW_RECOGNIZE_URL=http://openclaw-recognizer:19000/recognize

# 网关等待识别后端的超时时间（毫秒）
RECOGNIZER_TIMEOUT_MS=60000
