PORT=9000
MP_BASE_URL=http://moviepilot-v2:3001
MP_API_KEY=replace_with_moviepilot_api_key

# direct_llm or external_recognizer
RECOGNIZER_MODE=direct_llm

# direct_llm mode
# OpenAI-compatible endpoint base URL, without /chat/completions
# Examples:
# - https://api.openai.com/v1
# - https://dashscope.aliyuncs.com/compatible-mode/v1
# - https://openrouter.ai/api/v1
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=replace_with_llm_api_key
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.1

# optional TMDB verification
# strongly recommended if you want reliable tmdb_id completion
TMDB_API_KEY=

# external_recognizer mode
OPENCLAW_RECOGNIZE_URL=http://openclaw-recognizer:19000/recognize

RECOGNIZER_TIMEOUT_MS=30000
